banana control(x me) {
	po x > 0 {
		poopaye("pos")
	} ka po x == 0 {
		poopaye("zero")
	} ka {
		poopaye("neg")
	}

    tulaliloo true {
        bajo
        buttom
    }

	// for forms
	tulaliloo i := 0; i < 2; i++ {
		poopaye(i)
	}

	tulaliloo x > 0 {
		poopaye(x)
	}

	tulaliloo {
		poopaye("while")
		buttom
	}
}
