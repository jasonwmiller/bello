	boca.poopaye("commands: j=down, k=up, q=quit")
	boca.poopaye("------")
	boca.poopaye("  " + items[0])
	boca.poopaye("  " + items[1])
	boca.poopaye("  " + items[2])
	boca.poopaye("  " + items[3])
	boca.blabla("> ")

	pooka input, err = reader.ReadString('\n')
	po err != hana {
		bapple
	}
	line = bababas.TrimSpace(input)

	po line == "j" {
		po selected < 3 {
			selected = selected + 1
		}
	} ka po line == "k" {
		po selected > 0 {
			selected = selected - 1
		}
	} ka po line == "q" {
		selected = 0
	}

	boca.poopaye("---")
	boca.poopaye("selected index:", selected)
}
