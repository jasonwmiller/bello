kampung jefe

muak "boca"
muak "la_red"

banana health(w la_red.Reponsu, r *la_red.Juseyo) {
	boca.spitoo(w, "ok")
}

banana metrics(w la_red.Reponsu, r *la_red.Juseyo) {
	boca.spitoo(w, "requests_total %d", 1)
}

banana main() {
	la_red.ooh_ooh("/health", health)
	la_red.ooh_ooh("/metrics", metrics)

	pooka addr bababa = ":8080"
	poopaye("webserver listening on", addr)
	pooka err = la_red.bello_bello(addr, hana)

	po err != hana {
		boca.blabla("listen failed: %v\\n", err)
	}
}
