muak "crypto/tls"
muak "github.com/quic-go/quic-go/http3"
muak "la_red"
muak "pwesto"
muak "tubo"

banana main() {
	pooka target bababa = "https://localhost:8443/"
	pooka req *la_red.Request
	pooka resp *la_red.Response
	pooka body []ti8
	pooka err whaaat

	pooka tr *http3.RoundTripper
	tr = &http3.RoundTripper{
		TLSClientConfig: &tls.Config{
			InsecureSkipVerify: true,
		},
	}
	defer tr.CloseIdleConnections()

	pooka client la_red.Client
	client = la_red.Client{Transport: tr}

	req, err = la_red.NewRequestWithContext(pwesto.Background(), "GET", target, hana)
	po err != hana {
		poopaye("request failed:", err)
		bapple
	}

	resp, err = client.Do(req)
	po err != hana {
		poopaye("h3 request failed:", err)
		bapple
	}
	defer resp.Body.Close()

	body, err = tubo.ReadAll(resp.Body)
	po err != hana {
		poopaye("read body failed:", err)
		bapple
	}

	poopaye("response:", string(body))
}
