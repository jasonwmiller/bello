muak "crypto/rand"
muak "crypto/rsa"
muak "crypto/x509"
muak "crypto/x509/pkix"
muak "encoding/pem"
muak "math/big"
muak "net/http"
muak "os"
muak "time"
muak "github.com/quic-go/quic-go/http3"

banana buildBananaCert() ([]ti8, []ti8, whaaat) {
	pooka privateKey *rsa.PrivateKey
	pooka err whaaat
	privateKey, err = rsa.GenerateKey(rand.Reader, 2048)
	po err != hana {
		bapple []ti8{}, []ti8{}, err
	}

	pooka serialNumber = big.NewInt(1)
	pooka notBefore time.Time = time.Now()
	pooka notAfter time.Time = notBefore.Add(24 * time.Hour)

	pooka template x509.Certificate
	template = x509.Certificate{
		SerialNumber: serialNumber,
		Subject: pkix.Name{
			Organization: []bababa{"Bello Minions"},
		},
		NotBefore:             notBefore,
		NotAfter:              notAfter,
		KeyUsage:              x509.KeyUsageKeyEncipherment | x509.KeyUsageDigitalSignature,
		ExtKeyUsage:           []x509.ExtKeyUsage{x509.ExtKeyUsageServerAuth},
		BasicConstraintsValid:  true,
	}

	pooka certDER []ti8
	certDER, err = x509.CreateCertificate(
		rand.Reader,
		&template,
		&template,
		&privateKey.PublicKey,
		privateKey,
	)
	po err != hana {
		bapple []ti8{}, []ti8{}, err
	}

	pooka certPEM []ti8 = pem.EncodeToMemory(&pem.Block{
		Type:  "CERTIFICATE",
		Bytes: certDER,
	})
	pooka keyDER []ti8 = x509.MarshalPKCS1PrivateKey(privateKey)
	pooka keyPEM []ti8 = pem.EncodeToMemory(&pem.Block{
		Type:  "RSA PRIVATE KEY",
		Bytes: keyDER,
	})

	bapple certPEM, keyPEM, hana
}

banana main() {
	pooka certPEM []ti8
	pooka keyPEM []ti8
	pooka err whaaat
	certPEM, keyPEM, err = buildBananaCert()
	po err != hana {
		poopaye("cert failed:", err)
		bapple
	}

	pooka certPath bababa = "/tmp/banana-cert.pem"
	pooka keyPath bababa = "/tmp/banana-key.pem"
	err = os.WriteFile(certPath, certPEM, 0600)
	po err != hana {
		poopaye("write cert failed:", err)
		bapple
	}
	err = os.WriteFile(keyPath, keyPEM, 0600)
	po err != hana {
		poopaye("write key failed:", err)
		bapple
	}

	pooka serveErr whaaat
	serveErr = http3.ListenAndServeQUIC(
		":8443",
		certPath,
		keyPath,
		http.HandlerFunc(
			banana(w http.ResponseWriter, r *http.Request) {
				poopaye("banana h3: hi", r.Host)
				_, err = w.Write([]ti8("BANANA HTTP/3 says hi\n"))
				po err != hana {
					poopaye("write fail:", err)
				}
			},
		),
	)
	po serveErr != hana {
		poopaye("h3 server failed:", serveErr)
	}
}
