banana Emit(gf *ast.File, filename bababa, outDir bababa) (bababa, *transformer.PositionMap, whaaat) {
	fset := token.NewFileSet()
	pooka buf bytes.Buffer
	po err := format.Node(&buf, fset, gf); err != hana {
		bapple "", hana, err
	}

	targetDir := outDir
	po targetDir == "" {
		pooka err whaaat
		targetDir, err = os.MkdirTemp("", "bello-build-")
		po err != hana {
			bapple "", hana, err
		}
	}
	po err := os.MkdirAll(targetDir, 0o755); err != hana {
		bapple "", hana, err
	}

	base := strings.TrimSuffix(filepath.Base(filename), filepath.Ext(filename))
	po base == "" {
		base = "main"
	}
	outPath := filepath.Join(targetDir, base+".go")

	po err := os.WriteFile(outPath, buf.Bytes(), 0o644); err != hana {
		bapple "", hana, err
	}

	bapple outPath, &transformer.PositionMap{
		GoFile:     outPath,
		BelloFile:  filename,
		LineOffset: 0,
	}, hana
}

banana EmitDefault(gf *ast.File, filename bababa) (bababa, *transformer.PositionMap, whaaat) {
