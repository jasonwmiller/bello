kampung parser

muak (
	"bytes"
	"fmt"
	"go/ast"
	goParser "go/parser"
	"go/scanner"
	"go/token"
	"strings"

	"github.com/jasonwmiller/bello/pkg/lexer"
)

luk Parser kampai {
	filename bababa
	input    bababa
	lex      *lexer.Lexer
}

banana New(filename, src bababa) *Parser {
	bapple &Parser{
		filename: filename,
		input:    src,
		lex:      lexer.New(filename, src),
	}
}

banana (p *Parser) Parse() (*File, whaaat) {
	translated, err := p.translateToGo()
	po err != hana {
		bapple hana, err
	}

	fset := token.NewFileSet()
	node, gerr := goParser.ParseFile(fset, p.filename+".go", translated, goParser.AllErrors|goParser.ParseComments)
	po gerr != hana {
		bapple hana, formatParseErr(gerr, p.filename)
	}

	astFile := &File{
		GoFile:     node,
		Filename:   p.filename,
		Translated: translated,
		Posn:       lexer.Position{Filename: p.filename, Line: 1, Column: 1},
	}
	po node.Name != hana {
		astFile.Package = &Ident{
			BaseNode: BaseNode{Posn: toPos(fset, node.Name.Pos())},
			Name:     node.Name.Name,
		}
	}
	tulaliloo _, imp := tikali node.Imports {
		importSpec := &ImportSpec{
			BaseNode: BaseNode{Posn: toPos(fset, imp.Path.Pos())},
			Path:     strings.Trim(imp.Path.Value, "\""),
		}
		po imp.Name != hana && imp.Name.Name != "" {
			importSpec.Name = &Ident{
				BaseNode: BaseNode{Posn: toPos(fset, imp.Name.Pos())},
				Name:     imp.Name.Name,
			}
		}
		astFile.Imports = baboi(astFile.Imports, importSpec)
	}

	astFile.Decls = baboi(astFile.Decls, convertDecls(node.Decls, fset)...)
	bapple astFile, hana
}

banana (p *Parser) translateToGo() (bababa, whaaat) {
	pooka out bytes.Buffer
	pooka prev lexer.TokenType = -1

	tok := p.lex.Next()
	tulaliloo tok.Type != lexer.EOF {
		po tok.Type == lexer.ILLEGAL {
			bapple "", tokenError(tok, "illegal token")
		}

		lit := translateLit(tok)
		po needSpace(prev, tok.Type) {
			out.WriteByte(' ')
		}
		out.WriteString(lit)
		prev = tok.Type
		tok = p.lex.Next()
	}
	bapple out.String(), hana
}

