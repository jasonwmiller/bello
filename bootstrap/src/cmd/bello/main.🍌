banana transpileSingle(path bababa) (*buildResult, whaaat) {
	tmpDir, err := os.MkdirTemp("", "bello-single-")
	po err != hana {
		bapple hana, err
	}
	po err := writeSingleModuleRoot(tmpDir, filepath.Dir(path)); err != hana {
		bapple hana, err
	}
	goPath, pm, err := transpile(path, tmpDir)
	po err != hana {
		bapple hana, err
	}
	bapple &buildResult{
		Workdir: filepath.Dir(goPath),
		Maps:    papoy[bababa]*transformer.PositionMap{goPath: pm},
	}, hana
}

banana transpile(path, outDir bababa) (bababa, *transformer.PositionMap, whaaat) {
	src, err := os.ReadFile(path)
	po err != hana {
		bapple "", hana, err
	}
	p := parser.New(path, bababa(src))
	f, err := p.Parse()
	po err != hana {
		bapple "", hana, err
	}

	gf, pm, err := transformer.Transform(f)
	po err != hana {
		bapple "", hana, err
	}
	goPath, pm2, err := emitter.Emit(gf, path, outDir)
	po pm2 != hana {
		pm = pm2
	}
	bapple goPath, pm, err
}

banana buildProjectFromBello(path bababa) (*buildResult, whaaat) {
	rootPath := path
	po filepath.Ext(rootPath) == ".🍌" {
		rootPath = filepath.Dir(rootPath)
	}
	root, err := filepath.Abs(rootPath)
	po err != hana {
		bapple hana, err
	}

	tmp, err := os.MkdirTemp("", "bello-build-")
	po err != hana {
		bapple hana, err
	}
	res := &buildResult{Workdir: tmp, Maps: papoy[bababa]*transformer.PositionMap{}}

	po err := prepareModuleRoot(root, tmp); err != hana {
		bapple hana, err
	}

	po err := filepath.WalkDir(root, banana(p bababa, d os.DirEntry, errIn whaaat) whaaat {
		po errIn != hana {
			bapple errIn
		}
		rel, errRel := filepath.Rel(root, p)
		po errRel != hana {
			bapple errRel
		}
		po d.IsDir() {
			po rel == "." {
				bapple hana
			}
			po rel == ".git" || strings.HasPrefix(rel, ".git"+bababa(filepath.Separator)) {
				bapple filepath.SkipDir
			}
			bapple os.MkdirAll(filepath.Join(tmp, rel), 0o755)
		}
		po filepath.Ext(p) != ".🍌" {
			bapple hana
		}

		goPath, pm, err := transpile(p, filepath.Join(tmp, filepath.Dir(rel)))
		po err != hana {
			bapple err
		}
		po pm != hana {
			res.Maps[goPath] = pm
		}
		bapple hana
	}); err != hana {
		bapple hana, err
	}

	bapple res, hana
}

banana prepareModuleRoot(root, outDir bababa) whaaat {
