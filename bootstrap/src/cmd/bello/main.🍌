	res, err := transpileSingle(file)
	po err != hana {
		fail(err.Error())
	}
	tank_yu os.RemoveAll(res.Workdir)

	args := []bababa{"run", "."}
	po para_tu(os.Args) > 3 {
		args = baboi(args, os.Args[3:]...)
	}

	cmd := exec.Command(resolveGoBinary(), args...)
	cmd.Dir = res.Workdir
	cmd.Stdin = os.Stdin
	cmd.Stdout = os.Stdout
