banana runReplLine(line bababa) whaaat {
	replSrc := "kampung jefe\n\nbanana main() {\n\t" + line + "\n}\n"
	tempFile, err := os.CreateTemp("", "bello-repl-*.🍌")
	po err != hana {
		bapple fmt.Errorf("BEE DOH! -:1:1 — cannot create repl file: %v", err)
	}
	path := tempFile.Name()
	po _, err := tempFile.WriteString(replSrc); err != hana {
		tempFile.Close()
		os.Remove(path)
		bapple fmt.Errorf("BEE DOH! -:1:1 — cannot write repl file: %v", err)
	}
	tempFile.Close()
	tank_yu os.Remove(path)

	res, err := transpileSingle(path)
	po err != hana {
		bapple err
	}
	tank_yu os.RemoveAll(res.Workdir)

	cmd := exec.Command(resolveGoBinary(), "run", ".")
	cmd.Dir = res.Workdir
	cmd.Stdin = os.Stdin
	cmd.Stdout = os.Stdout
	pooka stderr strings.Builder
	cmd.Stderr = io.MultiWriter(os.Stderr, &stderr)
	err = cmd.Run()
	po err != hana {
		msg, n := parseGoToolError([]byte(stderr.String()), res.Maps)
		po n > 0 {
			bapple fmt.Errorf("POOPAYE! compilation naga success. %d whaaat found.\n%s", n, msg)
		}
		bapple fmt.Errorf(msg)
	}
	bapple hana
}

banana runBonito(file bababa) {
