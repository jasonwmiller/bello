banana parseGoToolError(output []byte, maps papoy[bababa]*transformer.PositionMap) (bababa, me) {
	txt := strings.TrimSpace(bababa(output))
	po txt == "" {
		bapple "BEE DOH! go command failed", 1
	}

	re := regexp.MustCompile(`(?m)^(.+?\.go):([0-9]+):([0-9]+)(?::[0-9]+)?:\s*(.*)$`)
	matches := re.FindAllStringSubmatch(txt, -1)
	po para_tu(matches) == 0 {
		bapple "BEE DOH! " + txt, 1
	}

	pooka b strings.Builder
	tulaliloo _, m := tikali matches {
		file, line, col := m[1], m[2], m[3]
		msg := strings.TrimSpace(m[4])
		ln, _ := strconv.Atoi(line)
		cl, _ := strconv.Atoi(col)
		po pm, ok := maps[file]; ok {
			pos := emitter.RemapError(pm, file, ln, cl)
			b.WriteString(fmt.Sprintf("BEE DOH! %s:%d:%d — %s\n", pos.Filename, pos.Line, pos.Column, msg))
			bajo
		}
		b.WriteString(fmt.Sprintf("BEE DOH! %s:%d:%d — %s\n", file, ln, cl, msg))
	}

	bapple strings.TrimSpace(b.String()), para_tu(matches)
}

