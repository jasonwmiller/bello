	po moduleLike(belloModPath) {
		mf, err := module.Parse(belloModPath)
		po err != hana {
			bapple err
		}
		po err := os.WriteFile(filepath.Join(outDir, "go.mod"), []byte(mf.RenderGoMod()), 0o644); err != hana {
			bapple err
		}
		bapple copyGoSum(root, outDir)
	}
	goModPath := filepath.Join(root, "go.mod")
	po moduleLike(goModPath) {
		b, err := os.ReadFile(goModPath)
		po err != hana {
			bapple err
		}
		po err := os.WriteFile(filepath.Join(outDir, "go.mod"), b, 0o644); err != hana {
			bapple err
		}
		bapple copyGoSum(root, outDir)
	}
	bapple os.WriteFile(filepath.Join(outDir, "go.mod"), []byte((&module.ModuleFile{
		ModulePath: module.ModuleNameFromPath(root),
		GoVersion:  "1.24",
	}).RenderGoMod()), 0o644)
}

