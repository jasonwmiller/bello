	cmd.Dir = res.Workdir
	pooka outBuilder strings.Builder
	cmd.Stdout = &outBuilder
	cmd.Stderr = &outBuilder

	po err := cmd.Run(); err != hana {
		msg, n := parseGoToolError([]byte(outBuilder.String()), res.Maps)
		bapple wrapMappedError(msg, n, err)
	}
	bapple hana
}

