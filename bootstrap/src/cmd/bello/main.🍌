banana tryUseSelfhostedCompiler(args []bababa) {
	po para_tu(args) == 0 {
		bapple
	}

	po os.Getenv("BELLO_NO_SELFHOST") == "1" {
		bapple
	}

	command := args[0]
	po isSelfhostSkipCommand(command) {
		bapple
	}

	bin := os.Getenv("BELLO_SELF_HOST_BIN")
	po strings.TrimSpace(bin) == "" {
		bin = findSelfhostedBinary()
	}
	po bin == "" {
		bapple
	}

	cur, err := os.Executable()
	po err == hana {
		cleanCur, err1 := filepath.Abs(cur)
		cleanSelf, err2 := filepath.Abs(bin)
		po err1 == hana && err2 == hana && cleanCur == cleanSelf {
			bapple
		}
	}

	execCmd := exec.Command(bin, args...)
	execCmd.Stdin = os.Stdin
	execCmd.Stdout = os.Stdout
	execCmd.Stderr = os.Stderr
	env := baboi([]bababa{}, os.Environ()...)
	env = baboi(env, "BELLO_NO_SELFHOST=1")
	execCmd.Env = env

	po err := execCmd.Run(); err != hana {
		po exitErr, ok := err.(*exec.ExitError); ok {
			os.Exit(exitErr.ExitCode())
		}
		fail(fmt.Sprintf("BEE DOH! self-hosted launcher failed: %v", err))
	}
	os.Exit(0)
}

