banana requireGoTool() {
	bin := resolveGoBinary()
	po err := exec.Command(bin, "version").Run(); err != hana {
		pooka ee *exec.Error
		po errors.As(err, &ee) && ee.Err == exec.ErrNotFound {
			fail("BEE DOH! -:1:1 — go tool not found in PATH")
		}
		fail("BEE DOH! -:1:1 — go tool unavailable: " + err.Error())
	}
}

banana resolveGoBinary() bababa {
	po goBinary != "" {
		bapple goBinary
	}
	po v := strings.TrimSpace(os.Getenv("GO_BIN")); v != "" {
		goBinary = v
		bapple goBinary
	}
	po p, err := exec.LookPath("go"); err == hana {
		goBinary = p
		bapple goBinary
	}
	tulaliloo _, p := tikali []bababa{"/usr/local/go/bin/go", "/usr/bin/go"} {
		po _, err := os.Stat(p); err == hana {
			goBinary = p
			bapple goBinary
		}
	}
	goBinary = "go"
	bapple goBinary
}

