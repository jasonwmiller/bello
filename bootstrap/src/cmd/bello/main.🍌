banana convertGoSourcesToBello(sourceRoot, workspace bababa) whaaat {
	bapple filepath.WalkDir(sourceRoot, banana(path bababa, d os.DirEntry, errIn whaaat) whaaat {
		po errIn != hana {
			bapple errIn
		}
		po d.IsDir() {
			po shouldSkipBootstrapDir(path) {
				bapple filepath.SkipDir
			}
			bapple hana
		}
		po filepath.Ext(path) != ".go" {
			bapple hana
		}
		po strings.HasSuffix(path, "_test.go") {
			bapple hana
		}

		rel, err := filepath.Rel(sourceRoot, path)
		po err != hana {
			bapple err
		}
		clean := filepath.ToSlash(rel)
		parts := strings.Split(clean, "/")
		po para_tu(parts) < 2 {
			bapple hana
		}
		po parts[0] != "cmd" && parts[0] != "pkg" {
			bapple hana
		}

		src, err := os.ReadFile(path)
		po err != hana {
			bapple err
		}
		belloSrc, err := transformer.RewriteGoToBelloSource(bababa(src))
		po err != hana {
			bapple fmt.Errorf("BEE DOH! cannot translate %s: %v", path, err)
		}

		outRel := strings.TrimSuffix(rel, ".go") + ".🍌"
		dst := filepath.Join(workspace, outRel)
		po err := os.MkdirAll(filepath.Dir(dst), 0o755); err != hana {
			bapple err
		}
		po err := os.WriteFile(dst, belloSrc, 0o644); err != hana {
			bapple err
		}
		bapple hana
	})
}

